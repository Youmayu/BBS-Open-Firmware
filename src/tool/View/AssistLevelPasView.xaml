<UserControl x:Class="BBSFW.View.AssistLevelPasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
	<StackPanel>
		<Grid Margin="0 0 0 14">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="220" />
			</Grid.ColumnDefinitions>
			<StackPanel>
				<TextBlock Text="PAS variant" FontWeight="SemiBold" />
				<TextBlock Text="Cadence uses a fixed assist target. Variable responds more dynamically but disables throttle on that assist level."
						   Foreground="{DynamicResource MutedTextBrush}"
						   TextWrapping="Wrap"
						   Margin="0 3 18 0" />
			</StackPanel>
			<ComboBox Grid.Column="1" ItemsSource="{Binding AssistPasVariantOptions}" SelectedValue="{Binding SelectedPasVariant, UpdateSourceTrigger=PropertyChanged}" />
		</Grid>

		<Grid Margin="0 0 0 14">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="120" />
			</Grid.ColumnDefinitions>
			<StackPanel>
				<TextBlock Text="Target current" FontWeight="SemiBold" />
				<TextBlock Text="Percent of global max current allowed for this assist level."
						   Foreground="{DynamicResource MutedTextBrush}"
						   TextWrapping="Wrap"
						   Margin="0 3 18 0" />
			</StackPanel>
			<TextBox Grid.Column="1" Text="{Binding TargetCurrentPercent, UpdateSourceTrigger=PropertyChanged}" />
		</Grid>

		<Grid Margin="0 0 0 14">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="120" />
			</Grid.ColumnDefinitions>
			<StackPanel>
				<TextBlock Text="Cadence limit" FontWeight="SemiBold" />
				<TextBlock Text="Percent of the cadence ceiling. Lower values make assist taper sooner at higher pedaling cadence."
						   Foreground="{DynamicResource MutedTextBrush}"
						   TextWrapping="Wrap"
						   Margin="0 3 18 0" />
			</StackPanel>
			<TextBox Grid.Column="1" Text="{Binding MaxCadencePercent, UpdateSourceTrigger=PropertyChanged}" />
		</Grid>

		<Grid Margin="0 0 0 14">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="120" />
			</Grid.ColumnDefinitions>
			<StackPanel>
				<TextBlock Text="Speed limit" FontWeight="SemiBold" />
				<TextBlock Text="Percent of the global max speed for this assist level."
						   Foreground="{DynamicResource MutedTextBrush}"
						   TextWrapping="Wrap"
						   Margin="0 3 18 0" />
			</StackPanel>
			<TextBox Grid.Column="1" Text="{Binding MaxSpeedPercent, UpdateSourceTrigger=PropertyChanged}" />
		</Grid>

		<StackPanel>
			<StackPanel.Style>
				<Style TargetType="{x:Type StackPanel}">
					<Style.Triggers>
						<DataTrigger Binding="{Binding IsPasAssistVariableVariant}" Value="True">
							<Setter Property="Visibility" Value="Collapsed" />
						</DataTrigger>
					</Style.Triggers>
				</Style>
			</StackPanel.Style>

			<CheckBox Content="Allow throttle in this assist level"
					  IsChecked="{Binding IsThrottleEnabled}"
					  Margin="0 0 0 8" />
			<TextBlock Text="Throttle will still obey the throttle current and override settings below."
					   Foreground="{DynamicResource MutedTextBrush}"
					   TextWrapping="Wrap"
					   Margin="0 0 0 14" />

			<Grid Margin="0 0 0 14">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="120" />
				</Grid.ColumnDefinitions>
				<StackPanel>
					<TextBlock Text="Throttle current" FontWeight="SemiBold" />
					<TextBlock Text="Percent of global max current allowed when using throttle in this assist level."
							   Foreground="{DynamicResource MutedTextBrush}"
							   TextWrapping="Wrap"
							   Margin="0 3 18 0" />
				</StackPanel>
				<TextBox Grid.Column="1" Text="{Binding MaxThrottlePercent, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsThrottleEnabled}" />
			</Grid>

			<TextBlock Text="Throttle overrides" FontWeight="SemiBold" />
			<TextBlock Text="When throttle asks for more power than pedal assist, these can lift cadence or speed limits to avoid the throttle feeling capped."
					   Foreground="{DynamicResource MutedTextBrush}"
					   TextWrapping="Wrap"
					   Margin="0 3 0 8" />
			<StackPanel Orientation="Horizontal">
				<CheckBox Content="Cadence override" IsChecked="{Binding IsThrottleCadenceOverrideEnabled}" IsEnabled="{Binding IsThrottleEnabled}" Margin="0 0 18 0" />
				<CheckBox Content="Speed override" IsChecked="{Binding IsThrottleSpeedOverrideEnabled}" IsEnabled="{Binding IsThrottleEnabled}" />
			</StackPanel>
		</StackPanel>
	</StackPanel>
</UserControl>
