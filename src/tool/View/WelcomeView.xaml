<UserControl x:Class="BBSFW.View.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="620"
             d:DesignWidth="860">
	<UserControl.Resources>
		<Style x:Key="PanelStyle" TargetType="{x:Type Border}">
			<Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}" />
			<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="CornerRadius" Value="8" />
			<Setter Property="Padding" Value="20" />
			<Setter Property="Margin" Value="0 0 0 16" />
		</Style>
	</UserControl.Resources>

	<Grid x:Name="WelcomeRoot" Opacity="0">
		<Grid.RenderTransform>
			<TranslateTransform x:Name="WelcomeMotion" Y="18" />
		</Grid.RenderTransform>
		<Grid.Triggers>
			<EventTrigger RoutedEvent="Loaded">
				<BeginStoryboard>
					<Storyboard>
						<DoubleAnimation Storyboard.TargetName="WelcomeRoot"
										 Storyboard.TargetProperty="Opacity"
										 From="0"
										 To="1"
										 Duration="0:0:0.30" />
						<DoubleAnimation Storyboard.TargetName="WelcomeMotion"
										 Storyboard.TargetProperty="Y"
										 From="18"
										 To="0"
										 Duration="0:0:0.34"
										 DecelerationRatio="0.72" />
					</Storyboard>
				</BeginStoryboard>
			</EventTrigger>
		</Grid.Triggers>

		<ScrollViewer VerticalScrollBarVisibility="Auto"
					  HorizontalScrollBarVisibility="Disabled">
			<StackPanel>
				<Border Background="{DynamicResource HeaderGradientBrush}"
						BorderBrush="{DynamicResource HeaderStrokeBrush}"
						BorderThickness="1"
						CornerRadius="8"
						Padding="28"
						Margin="0 0 0 18">
					<StackPanel>
						<TextBlock Text="BBS-FW Tool"
								   Foreground="{DynamicResource HeaderMutedTextBrush}"
								   FontWeight="SemiBold" />
						<TextBlock Text="Choose how you want to tune the controller"
								   FontSize="30"
								   FontWeight="SemiBold"
								   Foreground="{DynamicResource HeaderTextBrush}"
								   Margin="0 6 0 10"
								   TextWrapping="Wrap" />
						<TextBlock Text="Choose a setup mode, connect, read the current settings, then make changes."
								   Foreground="{DynamicResource HeaderMutedTextBrush}"
								   TextWrapping="Wrap"
								   MaxWidth="640" />
					</StackPanel>
				</Border>

				<Grid Margin="0 0 0 18">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="18" />
						<ColumnDefinition Width="*" />
					</Grid.ColumnDefinitions>

					<Border Grid.Column="0" Style="{StaticResource PanelStyle}">
						<StackPanel>
							<TextBlock Text="Easy mode"
									   FontSize="20"
									   FontWeight="SemiBold" />
							<TextBlock Text="Presets and the core settings most riders actually need: speed, current, battery cutoff, wheel size, display type, and basic assist feel."
									   Foreground="{DynamicResource MutedTextBrush}"
									   TextWrapping="Wrap"
									   Margin="0 6 0 18" />
							<Button Content="Continue with Easy mode"
									Click="ContinueEasy_Click" />
						</StackPanel>
					</Border>

					<Border Grid.Column="2" Style="{StaticResource PanelStyle}">
						<StackPanel>
							<TextBlock Text="Pro mode"
									   FontSize="20"
									   FontWeight="SemiBold" />
							<TextBlock Text="Full access to system behavior, assist levels, calibration, and diagnostics. Use this when you want complete control over the firmware settings."
									   Foreground="{DynamicResource MutedTextBrush}"
									   TextWrapping="Wrap"
									   Margin="0 6 0 18" />
							<Button Content="Continue with Pro mode"
									Style="{StaticResource SecondaryButtonStyle}"
									Click="ContinuePro_Click" />
						</StackPanel>
					</Border>
				</Grid>

				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="1.1*" />
						<ColumnDefinition Width="18" />
						<ColumnDefinition Width="0.9*" />
					</Grid.ColumnDefinitions>

					<Border Grid.Column="0" Style="{StaticResource PanelStyle}">
						<StackPanel>
							<TextBlock Text="Start here"
									   FontSize="20"
									   FontWeight="SemiBold" />
							<TextBlock Text="One step at a time."
									   Foreground="{DynamicResource MutedTextBrush}"
									   Margin="0 5 0 16" />

							<TextBlock Text="1. Open the connection page and choose the programming cable."
									   TextWrapping="Wrap"
									   Margin="0 0 0 10" />
							<TextBlock Text="2. Connect and read the controller to load the current settings."
									   TextWrapping="Wrap"
									   Margin="0 0 0 10" />
							<TextBlock Text="3. Continue in Easy or Pro mode, then write only after reviewing the values."
									   TextWrapping="Wrap"
									   Margin="0 0 0 16" />

							<Button Content="Open Connection"
									Width="150"
									Click="OpenConnection_Click" />
						</StackPanel>
					</Border>

					<Border Grid.Column="2" Style="{StaticResource PanelStyle}">
						<StackPanel>
							<TextBlock Text="Before writing"
									   FontSize="20"
									   FontWeight="SemiBold" />
							<TextBlock Text="Check battery limits against the real battery pack."
									   TextWrapping="Wrap"
									   Margin="0 5 0 10" />
							<TextBlock Text="Check wheel size and speed sensor settings so speed limiting behaves correctly."
									   TextWrapping="Wrap"
									   Margin="0 0 0 10" />
							<TextBlock Text="Use 860C only when that display is forcing ECO or Sport mode. P850C should stay on the standard display setting."
									   TextWrapping="Wrap" />
						</StackPanel>
					</Border>
				</Grid>
			</StackPanel>
		</ScrollViewer>
	</Grid>
</UserControl>
