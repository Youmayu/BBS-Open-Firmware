<UserControl x:Class="BBSFW.View.ConnectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500"
             d:DesignWidth="840">

	<UserControl.Resources>
		<BooleanToVisibilityConverter x:Key="BoolToVis" />

		<Style x:Key="ConnectionPanelStyle" TargetType="{x:Type Border}">
			<Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}" />
			<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="CornerRadius" Value="8" />
			<Setter Property="Padding" Value="20" />
		</Style>

		<Style x:Key="ConnectionStepStyle" TargetType="{x:Type Border}">
			<Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
			<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="CornerRadius" Value="8" />
			<Setter Property="Padding" Value="14" />
			<Setter Property="Margin" Value="0 0 0 10" />
		</Style>
	</UserControl.Resources>

	<Grid x:Name="ConnectionRoot" Opacity="0">
		<Grid.RenderTransform>
			<TranslateTransform x:Name="ConnectionMotion" Y="18" />
		</Grid.RenderTransform>
		<Grid.Triggers>
			<EventTrigger RoutedEvent="Loaded">
				<BeginStoryboard>
					<Storyboard>
						<DoubleAnimation Storyboard.TargetName="ConnectionRoot"
										 Storyboard.TargetProperty="Opacity"
										 From="0"
										 To="1"
										 Duration="0:0:0.30" />
						<DoubleAnimation Storyboard.TargetName="ConnectionMotion"
										 Storyboard.TargetProperty="Y"
										 From="18"
										 To="0"
										 Duration="0:0:0.34"
										 DecelerationRatio="0.72" />
					</Storyboard>
				</BeginStoryboard>
			</EventTrigger>
		</Grid.Triggers>

		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="1.18*" />
			<ColumnDefinition Width="18" />
			<ColumnDefinition Width="0.82*" />
		</Grid.ColumnDefinitions>

		<Border Grid.Column="0" Style="{StaticResource ConnectionPanelStyle}">
			<DockPanel LastChildFill="True">
				<Grid DockPanel.Dock="Top" Margin="0 0 0 14">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>

					<StackPanel>
						<TextBlock Text="Programming cable"
								   FontSize="20"
								   FontWeight="SemiBold" />
						<TextBlock Text="Choose the COM port for the USB programming cable."
								   Foreground="{DynamicResource MutedTextBrush}"
								   Margin="0 4 0 0" />
					</StackPanel>

					<Button Grid.Column="1"
							Content="Refresh"
							Style="{StaticResource SecondaryButtonStyle}"
							Width="96"
							VerticalAlignment="Top"
							Command="{Binding RefreshCommand}" />
				</Grid>

				<ListView ItemsSource="{Binding ComPorts}"
						  SelectedItem="{Binding SelectedComPort}"
						  MinHeight="350">
					<ListView.ItemTemplate>
						<DataTemplate>
							<Grid>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
								</Grid.RowDefinitions>
								<TextBlock Text="{Binding Name}"
										   FontWeight="SemiBold" />
								<TextBlock Grid.Row="1"
										   Text="{Binding Description}"
										   Foreground="{DynamicResource MutedTextBrush}"
										   TextWrapping="Wrap"
										   Margin="0 3 0 0" />
							</Grid>
						</DataTemplate>
					</ListView.ItemTemplate>
				</ListView>
			</DockPanel>
		</Border>

		<StackPanel Grid.Column="2">
			<Border Style="{StaticResource ConnectionPanelStyle}" Margin="0 0 0 16">
				<StackPanel>
					<TextBlock Text="Controller link"
							   FontSize="20"
							   FontWeight="SemiBold" />
					<TextBlock Text="Connect first, then read the controller before editing values."
							   Foreground="{DynamicResource MutedTextBrush}"
							   TextWrapping="Wrap"
							   Margin="0 4 0 18" />

					<Border Background="{DynamicResource AccentSoftBrush}"
							BorderBrush="{DynamicResource BorderBrush}"
							BorderThickness="1"
							CornerRadius="8"
							Padding="14"
							Margin="0 0 0 16">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<TextBlock Text="Selected port"
									   FontWeight="SemiBold" />
							<TextBlock Grid.Column="1"
									   Text="{Binding SelectedComPort.Name, TargetNullValue='No port selected', FallbackValue='No port selected'}"
									   Foreground="{DynamicResource MutedTextBrush}"
									   TextTrimming="CharacterEllipsis" />
						</Grid>
					</Border>

					<StackPanel Visibility="{Binding IsDisconnected, Converter={StaticResource BoolToVis}}">
						<Button Content="Connect"
								Height="38"
								Command="{Binding ConnectCommand}">
							<Button.Style>
								<Style TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
									<Setter Property="IsEnabled" Value="True" />
									<Setter Property="Visibility" Value="Visible" />
									<Style.Triggers>
										<DataTrigger Binding="{Binding SelectedComPort}" Value="{x:Null}">
											<Setter Property="IsEnabled" Value="False" />
										</DataTrigger>
										<DataTrigger Binding="{Binding IsConnecting}" Value="True">
											<Setter Property="Visibility" Value="Collapsed" />
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</Button.Style>
						</Button>

						<Button Content="Cancel"
								Style="{StaticResource SecondaryButtonStyle}"
								Height="38"
								Command="{Binding DisconnectCommand}"
								Visibility="{Binding IsConnecting, Converter={StaticResource BoolToVis}}" />

						<ProgressBar IsIndeterminate="True"
									 Height="7"
									 Margin="0 14 0 0"
									 Visibility="{Binding IsConnecting, Converter={StaticResource BoolToVis}}" />
					</StackPanel>

					<StackPanel Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}">
						<Button Content="Disconnect"
								Style="{StaticResource SecondaryButtonStyle}"
								Height="38"
								Command="{Binding DisconnectCommand}" />

						<Grid Margin="0 16 0 0">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto" />
								<RowDefinition Height="Auto" />
								<RowDefinition Height="Auto" />
							</Grid.RowDefinitions>

							<TextBlock Text="Controller" FontWeight="SemiBold" />
							<TextBlock Grid.Column="1" Text="{Binding Controller}" Foreground="{DynamicResource MutedTextBrush}" />

							<TextBlock Grid.Row="1" Text="Firmware" FontWeight="SemiBold" Margin="0 8 0 0" />
							<TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FirmwareVersion}" Foreground="{DynamicResource MutedTextBrush}" Margin="0 8 0 0" />

							<TextBlock Grid.Row="2" Text="Config" FontWeight="SemiBold" Margin="0 8 0 0" />
							<TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ConfigVersion}" Foreground="{DynamicResource MutedTextBrush}" Margin="0 8 0 0" />
						</Grid>
					</StackPanel>
				</StackPanel>
			</Border>

			<TextBlock Text="Programming workflow"
					   FontSize="18"
					   FontWeight="SemiBold"
					   Margin="0 0 0 12" />

			<Border Style="{StaticResource ConnectionStepStyle}">
				<TextBlock TextWrapping="Wrap">
					<Run FontWeight="SemiBold" Text="1. Select the cable. " />
					<Run Text="Use Refresh if the cable was connected after launch." />
				</TextBlock>
			</Border>

			<Border Style="{StaticResource ConnectionStepStyle}">
				<TextBlock TextWrapping="Wrap">
					<Run FontWeight="SemiBold" Text="2. Connect to the controller. " />
					<Run Text="The model and firmware version should appear before you read or write flash." />
				</TextBlock>
			</Border>

			<Border Style="{StaticResource ConnectionStepStyle}">
				<TextBlock TextWrapping="Wrap">
					<Run FontWeight="SemiBold" Text="3. Read before writing. " />
					<Run Text="Start from the current controller values, then save a backup XML before making changes." />
				</TextBlock>
			</Border>
		</StackPanel>
	</Grid>
</UserControl>
